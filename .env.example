# Optional local / CI overrides (not required for static Cloudflare Pages deploy)
# Copy to .env and fill only if you use wrangler non-interactively.

# Cloudflare account (wrangler pages deploy / CI)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# Public site origin (docs / client examples)
# PUBLIC_SITE_URL=https://mossymesh.com
