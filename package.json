{
  "name": "mossymesh-com",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Official website for MossyMesh - mossymesh.com",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
